{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/git-branch-pr-guard.sh",
        "matcher": "^(git\\s+(commit|push)\\b|gh\\s+pr\\s+create\\b)",
        "failClosed": true
      },
      {
        "command": ".cursor/hooks/backend-pytest-precommit-guard.sh",
        "matcher": "^git\\s+commit\\b",
        "failClosed": true
      },
      {
        "command": ".cursor/hooks/playwright-precommit-guard.sh",
        "matcher": "^git\\s+commit\\b",
        "failClosed": true
      }
    ]
  }
}
