# --- GitHub OAuth App ---------------------------------------------------------
# Create one at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3001/api/auth/callback/github
GITHUB_CLIENT_ID=aaa
GITHUB_CLIENT_SECRET=bbb

# --- Auth.js core -------------------------------------------------------------
# Random 32+ byte secret for Auth.js's own session encryption (not the bridge).
# Generate with: openssl rand -base64 32
AUTH_SECRET=BSJ+90ZpKnKw7hCXGf2VneC+vwcJ50pxKvGRSPB3Rf4=

# Public URL of this service. Auth.js uses this to build OAuth callback URLs.
AUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# --- FastAPI bridge -----------------------------------------------------------
# Shared HMAC secret with the FastAPI backend. MUST match the FastAPI
# GITHUB_BRIDGE_SECRET environment variable.
GITHUB_BRIDGE_SECRET=changethis-bridge-secret-please-rotate
GITHUB_BRIDGE_AUDIENCE=fastapi-bridge
GITHUB_BRIDGE_ISSUER=authjs

# --- Frontend handoff ---------------------------------------------------------
# After signing in we redirect the browser to this URL with a bridge token
# query parameter. Must point at the React frontend's /auth/callback route.
FRONTEND_CALLBACK_URL=http://localhost:5173/auth/callback
